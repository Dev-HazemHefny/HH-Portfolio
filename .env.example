# Environment Variables
# Copy this file to .env.local and add your actual values

# API Endpoints (if using external services)
# NEXT_PUBLIC_API_URL=your_api_url_here

# Email Service (choose one)
# For Nodemailer
NEXT_PUBLIC_SMTP_HOST=smtp.gmail.com
NEXT_PUBLIC_SMTP_PORT=587
NEXT_PUBLIC_SMTP_USER=your_email@gmail.com
NEXT_PUBLIC_SMTP_PASS=your_app_password

# For SendGrid
# NEXT_PUBLIC_SENDGRID_API_KEY=your_sendgrid_key

# For Formspree
# NEXT_PUBLIC_FORMSPREE_ID=your_formspree_id

# Analytics (optional)
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX-X
# NEXT_PUBLIC_HOTJAR_ID=your_hotjar_id

# Custom Domain (for deployment)
# NEXT_PUBLIC_DOMAIN=yourdomain.com
